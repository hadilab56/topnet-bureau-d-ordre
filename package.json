{
  "name": "topnet-registry",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "desktop": "npm run build && electron .",
    "package-win": "npm run build && electron-packager . TopnetRegistryBO --platform=win32 --arch=x64 --out=dist-desktop --overwrite --prune",
    "make-shortcut": "node create-shortcut.js"
  },
  "dependencies": {
    "mongodb-memory-server": "^11.2.0",
    "mongoose": "^9.7.4",
    "png-to-ico": "^3.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1"
  },
  "build": {
    "appId": "com.topnet.registry",
    "productName": "TopnetRegistryBO",
    "win": {
      "target": [
        "portable"
      ]
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "output": "dist-desktop"
    }
  }
}
